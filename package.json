    "commander": "^13.1.0",
    "fastify": "^5.3.3",
    "jsdom": "^26.1.0",
    "playwright": "^1.52.0",
    "turndown": "^7.2.0",
    "uuid": "^11.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.15.17",
    "@types/turndown": "^5.0.5",
    "@types/uuid": "^10.0.0",
