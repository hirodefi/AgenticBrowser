{
  "name": "agentic-browser",
  "version": "0.1.0",
  "description": "Fully autonomous browser runtime for AI agents. Zero human intervention needed.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "agentic-browser": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
